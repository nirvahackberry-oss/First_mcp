# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Zoho OAuth (https://api-console.zoho.in/)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
# ZOHO_ACCESS_TOKEN is refreshed automatically and saved back to .env.
# ZOHO_REFRESH_TOKEN only needs to be set once via: python get_zoho_token.py <auth_code>
ZOHO_REFRESH_TOKEN=
ZOHO_ACCESS_TOKEN=

# Zoho Sheet
ZOHO_WORKBOOK_ID=
ZOHO_SHEET_ID=0
ZOHO_ACCOUNTS_URL=https://accounts.zoho.in
ZOHO_SHEET_API_URL=https://sheet.zoho.in/api/v2

# Optional: OAuth redirect for get_zoho_token.py
ZOHO_REDIRECT_URI=http://localhost:8080/callback
